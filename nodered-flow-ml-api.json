  {
    "id": "process_predictions",
    "type": "function",
    "z": "ml_predictor_flow",
    "name": "Extract Predictions & Alert",
    "func": "// Extract predictions from API response\nconst predictions = msg.payload.predictions || {};\nconst co = predictions.co || 0;\nconst ethanol = predictions.ethanol || 0;\nconst temperature = predictions.temperature || 0;\nconst processingTime = msg.payload.processing_time_ms || 0;\n\n// Alert thresholds\nconst CO_THRESHOLD = 0.7;\nconst ETHANOL_THRESHOLD = 0.6;\nconst TEMP_THRESHOLD = 0.8;\n\n// Determine alert status\nlet alertLevel = \"normal\";\nlet alertMsg = \"All values normal\";\n\nif (co > CO_THRESHOLD) {\n    alertLevel = \"danger\";\n    alertMsg = `⚠️ HIGH CO DETECTED: ${co.toFixed(4)}`;\n} else if (ethanol > ETHANOL_THRESHOLD) {\n    alertLevel = \"warning\";\n    alertMsg = `⚠️ High Ethanol: ${ethanol.toFixed(4)}`;\n} else if (temperature > TEMP_THRESHOLD) {\n    alertLevel = \"warning\";\n    alertMsg = `⚠️ High Temperature: ${temperature.toFixed(4)}`;\n}\n\n// Prepare output message\nmsg.predictions = {\n    co: co,\n    ethanol: ethanol,\n    temperature: temperature,\n    alert_level: alertLevel,\n    alert_message: alertMsg,\n    processing_time_ms: processingTime,\n    timestamp: msg.payload.timestamp\n};\n\n// Set node status\nlet statusColor = \"green\";\nif (alertLevel === \"warning\") statusColor = \"yellow\";\nif (alertLevel === \"danger\") statusColor = \"red\";\n\nnode.status({\n    fill: statusColor,\n    shape: \"dot\",\n    text: alertMsg\n});\n\n// Send alert if needed\nif (alertLevel !== \"normal\") {\n    msg.alert = {\n        level: alertLevel,\n        message: alertMsg,\n        values: { co, ethanol, temperature }\n    };\n    return [msg, msg]; // Output to both normal and alert flows\n}\n\nreturn [msg, null];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1290,
    "y": 180,
    "wires": [
      [
        "write_predictions_to_influx"
      ],
      [
        "send_alert"
      ]
    ]
  },
  {
    "id": "write_predictions_to_influx",
    "type": "function",
    "z": "ml_predictor_flow",
    "name": "Format for InfluxDB",
    "func": "// Prepare predictions for InfluxDB\nconst pred = msg.predictions;\n\n// InfluxDB node expects simple object in msg.payload\nmsg.payload = {\n    pred_co: pred.co,\n    pred_ethanol: pred.ethanol,\n    pred_temperature: pred.temperature,\n    alert_level: pred.alert_level === \"danger\" ? 2 : (pred.alert_level === \"warning\" ? 1 : 0),\n    processing_time_ms: pred.processing_time_ms\n};\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1540,
    "y": 180,
    "wires": [
      [
        "influx_predictions"
      ]
    ]
  },
