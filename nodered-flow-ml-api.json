  {
    "id": "generate_sensor_data",
    "type": "function",
    "z": "ml_predictor_flow",
    "name": "Generate MQ135 & MQ5",
    "func": "// Simulate sensor readings\nconst mq135 = (Math.random() * 400 + 100).toFixed(2);\nconst mq5 = (Math.random() * 300 + 50).toFixed(2);\n\n// Prepare for ML API\nmsg.ml_payload = {\n    MQ135: parseFloat(mq135),\n    MQ5: parseFloat(mq5)\n};\n\n// Store in InfluxDB - InfluxDB node needs msg.payload directly\nmsg.payload = {\n    MQ135: parseFloat(mq135),\n    MQ5: parseFloat(mq5)\n};\n\nmsg.sensor_values = `MQ135=${mq135}, MQ5=${mq5}`;\nnode.status({fill:\"green\",shape:\"dot\",text:msg.sensor_values});\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 390,
    "y": 140,
    "wires": [
      [
        "write_to_influx",
        "debug_sensor",
        "delay_for_influx"
      ]
    ]
  },
