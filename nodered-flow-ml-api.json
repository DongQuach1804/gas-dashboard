    "z": "ml_predictor_flow",
    "name": "Prepare API Payload",
    "func": "// Prepare payload for FastAPI\nmsg.payload = msg.ml_payload;\nmsg.headers = {\n    'Content-Type': 'application/json'\n};\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
