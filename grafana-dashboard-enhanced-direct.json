    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "⚠️ Trạng thái Hệ thống (SVM Status)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "query": "SELECT last(\"svm_status\") FROM \"gas_predictions\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "datasource": {"type": "influxdb"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "✅ AN TOÀN",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "⚠️ CẢNH BÁO",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "🚨 NGUY HIỂM",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "value_and_name",
        "text": {
          "titleSize": 18,
          "valueSize": 40
        }
      }
    },
